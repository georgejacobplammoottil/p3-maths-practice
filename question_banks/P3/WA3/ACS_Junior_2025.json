    {
      "structure_id": "units_method_comparison_word_problem",
      "topic": "mixed_wa3",
      "section": "B",
      "marks": 2,
      "text": "5 chairs cost as much as 3 tables. A table costs $90. What is the cost of 1 chair?",
      "options": null,
      "correct_option": null,
      "answer": "$54",
      "working": "3 tables = 3 × $90 = $270. 5 chairs = $270. 1 chair = $270 ÷ 5 = $54",
      "source": "ACS Junior 2025 WA3 Q12"
    },
    {
      "structure_id": "multiplicative_chain_word_problem",
      "topic": "mixed_wa3",
      "section": "C",
      "marks": 3,
      "text": "Ming has some eggs. Crystal has twice as many eggs as Ming. Rahim has 3 times as many eggs as Crystal. Rahim has 320 more eggs than Crystal. How many eggs do they have altogether?",
      "options": null,
      "correct_option": null,
      "answer": "720",
      "working": "Let Ming = 1u. Crystal = 2u. Rahim = 6u. Rahim - Crystal = 4u = 320. 1u = 80. Total = 1u + 2u + 6u = 9u = 720",
      "source": "ACS Junior 2025 WA3 Q14"
    },
    {
      "structure_id": "two_step_subtract_then_multiply_word_problem",
      "topic": "mixed_wa3",
      "section": "C",
      "marks": 3,
      "text": "Sonia used 120 g of sugar to bake an almond cake. She used 25 g of almond powder less than the amount of sugar used. She used 4 times as much flour as the amount of almond powder used. What was the mass of flour Sonia used?",
      "options": null,
      "correct_option": null,
      "answer": "380",
      "working": "Almond powder = 120 - 25 = 95 g. Flour = 95 × 4 = 380 g",
      "source": "ACS Junior 2025 WA3 Q15"
    }
  ]
